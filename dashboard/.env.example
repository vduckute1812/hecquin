# Copy to `.env` and adjust.  Loaded by pydantic-settings (see config.py).

# Path to the SQLite file written by the C++ side (LearningStore).
# On the Pi this usually lives under the `sound/.env/` tree.
HECQUIN_DB_PATH=/home/pi/hecquin/sound/.env/data/hecquin.db

# Bind address + port. 0.0.0.0 exposes on the LAN; router forwards WAN:8443 → 443.
HECQUIN_HOST=0.0.0.0
HECQUIN_PORT=443

# Paths to the PEM-encoded cert + key. Generate with scripts/gen_self_signed_cert.sh.
# Leave empty to run plain HTTP (dev only; never over the WAN).
HECQUIN_SSL_CERT=certs/server.crt
HECQUIN_SSL_KEY=certs/server.key

# Bearer token required for /api/* and dashboard pages (except /health).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable auth (dev / LAN-only).
HECQUIN_AUTH_TOKEN=

# Comma-separated allowlist of CORS origins. Leave empty to disable CORS.
HECQUIN_CORS_ORIGINS=

# Log level: DEBUG / INFO / WARNING / ERROR
HECQUIN_LOG_LEVEL=INFO

# Default range (days) used by dashboard aggregations.
HECQUIN_DEFAULT_DAYS=30

#
# Example environment file for hecquin sound — copy to `.env/<platform>/config.env`
# or point `ConfigStore` at your own path. Do not commit files with real API keys.
#
# AI keys (first non-empty wins in AiClientConfig::from_store):
OPENAI_API_KEY=
HECQUIN_AI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# OpenAI-compatible API base (empty → https://api.openai.com/v1).
HECQUIN_AI_BASE_URL=
OPENAI_BASE_URL=

HECQUIN_AI_MODEL=
OPENAI_MODEL=

HECQUIN_AI_EMBEDDING_MODEL=
OPENAI_EMBEDDING_MODEL=
HECQUIN_AI_EMBEDDING_DIM=768

AUDIO_DEVICE_INDEX=-1

HECQUIN_LEARNING_DB_PATH=shared/learning/db/learning.sqlite
HECQUIN_LEARNING_CURRICULUM_DIR=shared/learning/curriculum
HECQUIN_LEARNING_CUSTOM_DIR=shared/learning/custom
HECQUIN_LEARNING_RAG_TOPK=3

HECQUIN_LESSON_START_PHRASES=start english lesson|begin lesson|start lesson
HECQUIN_LESSON_END_PHRASES=exit lesson|end lesson|stop lesson

HECQUIN_INGEST_API_LOG_CSV=shared/learning/api_calls.csv
HECQUIN_INGEST_RUN_SUMMARY_CSV=shared/learning/runs.csv

HECQUIN_PRONUNCIATION_MODEL=shared/models/pronunciation/wav2vec2_phoneme.onnx
HECQUIN_WITH_CURL=1
